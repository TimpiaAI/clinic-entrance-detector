# === Video Source ===
VIDEO_SOURCE=webcam
WEBCAM_INDEX=0
RTSP_URL=
VIDEO_FILE=
FRAME_WIDTH=1280
FRAME_HEIGHT=720
TARGET_FPS=15

# === Detection ===
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_CLASSES=0
TRACKER=bytetrack.yaml

# === Entry Detection Thresholds ===
BBOX_GROWTH_RATIO=1.3
Y_MOVEMENT_THRESHOLD=50
DWELL_TIME_MIN=1.5
DWELL_TIME_MAX=15.0
ENTRY_CONFIDENCE_THRESHOLD=0.6
TRAJECTORY_HISTORY_SECONDS=5

# === Webhook ===
WEBHOOK_URL=https://example.com/webhook
WEBHOOK_TIMEOUT=5
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY=2
WEBHOOK_COOLDOWN_PERSON=30
WEBHOOK_COOLDOWN_GLOBAL=3
WEBHOOK_INCLUDE_SNAPSHOT=true
WEBHOOK_SECRET=

# === Cleanup ===
PERSON_TIMEOUT=5
MAX_TRACKED_PERSONS=50
ENTRY_LOG_SIZE=100

# === Dashboard ===
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0

# === Calibration ===
CALIBRATION_FILE=calibration.json

# === Metadata / Logging ===
CAMERA_ID=clinic_entrance_01
LOG_LEVEL=INFO
