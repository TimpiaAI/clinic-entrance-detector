DWELL_TIME_MAX=15.0
ENTRY_CONFIDENCE_THRESHOLD=0.6
TRAJECTORY_HISTORY_SECONDS=5

# === Zone Tuning ===
ZONE_B_SPLIT_RATIO=0.35
MIN_ZONE_B_FRAMES=5
MIN_BBOX_AREA=2000

# === Webhook ===
WEBHOOK_URL=http://100.65.23.169:5050/trigger
WEBHOOK_TIMEOUT=5
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY=2
WEBHOOK_COOLDOWN_PERSON=30
WEBHOOK_COOLDOWN_GLOBAL=3
WEBHOOK_INCLUDE_SNAPSHOT=true
